# Telegram Bot API
API_ID=your_api_id
API_HASH=your_api_hash
BOT_TOKEN=your_bot_token

# Admin Configuration
OWNER_IDS=123456789,987654321
ADMIN_IDS=123456789,987654321

# Database (PostgreSQL Recommended for Production)
DATABASE_URL=postgresql://bot:bot_password@db:5432/botdb
# DATABASE_URL=sqlite+aiosqlite:///data/bot.db

# Postgres Credentials (Must match DATABASE_URL if using 'db' service)
POSTGRES_USER=bot
POSTGRES_PASSWORD=bot_password
POSTGRES_DB=botdb

# Persistence Paths (Defaults for Docker)
DATA_DIR=data
SESSIONS_DIR=sessions
LOG_DIR=logs

# Cache Configuration
CACHE_TTL=300

# Logging
LOG_LEVEL=INFO
